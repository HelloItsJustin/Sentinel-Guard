# Optional configuration for the SentinelGuard prototype backend.

# SQLite DB file path (relative to `backend/` when you run uvicorn from there)
SENTINELGUARD_DB_PATH=sentinelguard.db

# Comma-separated allowed CORS origins for the UI dev server
SENTINELGUARD_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

